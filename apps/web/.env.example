# ─── Figma API ───────────────────────────────────────────────
FIGMA_API_TOKEN=figd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIGMA_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIGMA_TEAM_ID=1234567890
FIGMA_DS_FILE_KEY=your-figma-ds-file-key  # Design System Figma file key (for pnpm ds:sync)
FIGMA_DS_FILE_KEYS=key1,key2,key3          # Optional comma-separated DS file keys

# ─── OpenAI API ──────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o                # Options: gpt-4o, gpt-4o-mini, gpt-4-turbo

# ─── Segment CDP ─────────────────────────────────────────────
NEXT_PUBLIC_SEGMENT_WRITE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── GitHub (for git automation) ─────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=martech-website-builder

# ─── AWS Amplify ─────────────────────────────────────────────
AMPLIFY_APP_ID=xxxxxxxxxxxx
AMPLIFY_BRANCH=main
AWS_REGION=us-east-1

# ─── App Settings ────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
LOG_LEVEL=debug
