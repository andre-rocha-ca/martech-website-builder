{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "generate": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "create-page": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "sync": {
      "cache": false,
      "dependsOn": []
    },
    "clean": {
      "cache": false
    }
  }
}
